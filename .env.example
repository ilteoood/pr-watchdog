# GitHub token used to authenticate API calls (needs repo scope / write access).
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Comma, space, or newline separated list of repositories to watch (owner/repo).
WATCHED_REPOS=ilteoood/repo,my-org/another-repo

# Cron expression (7 fields: sec min hour day month day-of-week year).
# Default below runs every 5 minutes, 8am-6pm, Monday-Friday.
CRON_PATTERN=0 */5 8-18 * * Mon-Fri *

# Optional: logging verbosity (e.g. info, debug, pr_watchdog=debug).
RUST_LOG=info
